{
  "name": "@t2tx/iris",
  "version": "0.1.21",
  "description": "Slack ⇄ Claude Code bridge (minimal, self-hosted). Socket Mode + Bolt.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "iris": "dist/cli.js"
  },
  "files": [
    "dist",
    "iris.config.example.toml",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:sea": "sh scripts/build-sea.sh",
    "build:sea:signed": "sh scripts/build-sea-signed.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" && pnpm lint:complexity",
    "lint:code": "eslint \"src/**/*.ts\"",
    "lint:complexity": "sh scripts/check-complexity.sh",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=lcov.info \"src/**/*.test.ts\"",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "prepublishOnly": "pnpm verify && pnpm build",
    "prepare": "command -v lefthook >/dev/null 2>&1 && lefthook install || true"
  },
  "dependencies": {
    "@slack/bolt": "^4.2.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^17.6.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "slack",
    "claude",
    "claude-code",
    "bridge",
    "socket-mode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t2tx/iris.git"
  },
  "homepage": "https://github.com/t2tx/iris#readme",
  "bugs": {
    "url": "https://github.com/t2tx/iris/issues"
  }
}
